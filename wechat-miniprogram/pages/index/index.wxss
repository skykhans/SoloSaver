.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.hero {
  padding: 10rpx 4rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.eyebrow {
  color: #1e9f58;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  color: #18211c;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.2;
}

.panel {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #ffffff;
  border: 1rpx solid #dce8dc;
  border-radius: 16rpx;
  box-shadow: 0 16rpx 46rpx rgba(25, 39, 29, 0.08);
}

.input {
  width: 100%;
  min-height: 220rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: #f8fbf6;
  border: 1rpx solid #c7dec8;
  border-radius: 14rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.actions {
  margin-top: 18rpx;
  display: flex;
  gap: 14rpx;
}

.actions.two {
  flex-wrap: wrap;
}

.btn {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  padding: 0 16rpx;
  border: 1rpx solid #23c45a;
  border-radius: 12rpx;
  background: #f4fbf6;
  color: #178b48;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 78rpx;
}

.btn.primary {
  background: #23c45a;
  color: #ffffff;
}

.btn.ghost {
  background: #ffffff;
}

.btn[disabled] {
  opacity: 0.55;
}

.task-head,
.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.task-title,
.section-title text:first-child {
  color: #18211c;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.status {
  flex: none;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef4ef;
  color: #67746c;
  font-size: 22rpx;
  font-weight: 700;
}

.status.extracted {
  background: #e8faee;
  color: #15924a;
}

.status.failed {
  background: #fff0f1;
  color: #d43b4a;
}

.link,
.meta,
.count,
.row-meta,
.empty {
  color: #748077;
  font-size: 24rpx;
  line-height: 1.45;
}

.link {
  display: block;
  margin-top: 12rpx;
  word-break: break-all;
}

.meta {
  display: block;
  margin-top: 12rpx;
}

.video {
  width: 100%;
  height: 420rpx;
  margin-top: 20rpx;
  background: #000000;
  border-radius: 14rpx;
  overflow: hidden;
}

.video-tabs {
  width: 100%;
  margin-top: 16rpx;
  white-space: nowrap;
}

.video-chip {
  display: inline-block;
  height: 58rpx;
  margin-right: 12rpx;
  padding: 0 22rpx;
  border: 1rpx solid #cfe2d2;
  border-radius: 999rpx;
  background: #ffffff;
  color: #5f7164;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 58rpx;
}

.video-chip.active {
  border-color: #23c45a;
  background: #e9fbf0;
  color: #15924a;
}

.images {
  width: 100%;
  margin-top: 20rpx;
  white-space: nowrap;
}

.image-card {
  display: inline-block;
  width: 220rpx;
  margin-right: 14rpx;
  vertical-align: top;
}

.image {
  width: 220rpx;
  height: 220rpx;
  border-radius: 14rpx;
  background: #eef3ef;
}

.mini-btn {
  width: 100%;
  height: 58rpx;
  margin-top: 10rpx;
  border: 1rpx solid #23c45a;
  border-radius: 10rpx;
  background: #ffffff;
  color: #178b48;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 58rpx;
}

.mini-btn[disabled] {
  opacity: 0.55;
}

.empty {
  margin-top: 18rpx;
  padding: 22rpx;
  background: #f7faf7;
  border-radius: 12rpx;
}

.task-row {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 1rpx solid #e4ebe4;
  border-radius: 14rpx;
  background: #fbfcfb;
}

.task-row.active {
  border-color: #94deb0;
  background: #edfbf1;
}

.row-title {
  display: block;
  color: #243029;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.row-meta {
  display: block;
  margin-top: 8rpx;
}
